<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>#if(pageTitle):#(pageTitle)#else:My App#endif</title>
    #clerkScript()
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background: #fff;
            color: #111;
        }
        header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 1.5rem;
            height: 56px;
            border-bottom: 1px solid #e5e7eb;
        }
        header .logo {
            font-weight: 700;
            font-size: 1.1rem;
            text-decoration: none;
            color: inherit;
        }
        header nav { display: flex; align-items: center; gap: 1rem; }
        header nav a {
            text-decoration: none;
            color: #374151;
            font-size: 0.9rem;
        }
        header nav a:hover { color: #111; }
        main { padding: 2rem 1.5rem; max-width: 960px; margin: 0 auto; }
    </style>
</head>
<body>
    <!-- Hide auth sections immediately via JS before render, avoiding a CSS class race -->
    <script>
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.clerk-signed-in, .clerk-signed-out')
            .forEach(function (el) { el.style.display = 'none'; });
    });
    </script>

    <header>
        <a class="logo" href="/">#if(appName):#(appName)#else:My App#endif</a>
        <nav>
            <div class="clerk-signed-in">
                <div id="clerk-user-button-nav"></div>
            </div>
            <div class="clerk-signed-out">
                <a href="/sign-in">Sign in</a>
                <a href="/sign-up">Sign up</a>
            </div>
        </nav>
    </header>

    <main>
        #import("body")
    </main>

    <script>
    (async function () {
        await new Promise(function (resolve) {
            if (window.Clerk) { resolve(); return; }
            var t = setInterval(function () {
                if (window.Clerk) { clearInterval(t); resolve(); }
            }, 50);
        });

        await window.Clerk.load();

        var signedIn  = document.querySelectorAll('.clerk-signed-in');
        var signedOut = document.querySelectorAll('.clerk-signed-out');

        if (window.Clerk.user) {
            signedIn.forEach(function (el)  { el.style.display = ''; });
            signedOut.forEach(function (el) { el.style.display = 'none'; });
            var navBtn = document.getElementById('clerk-user-button-nav');
            if (navBtn) { window.Clerk.mountUserButton(navBtn); }
        } else {
            signedIn.forEach(function (el)  { el.style.display = 'none'; });
            signedOut.forEach(function (el) { el.style.display = ''; });
        }
    })();
    </script>
</body>
</html>
